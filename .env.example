GEMINI_API_KEY=your_key_here
GEMINI_MODEL=

# Whisper local (gratis) usado cuando "Modo Pro" está activado en la UI
WHISPER_MODEL=base
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
WHISPER_LANGUAGE=

# Para asegurar que el backend use el Python de la venv
PYTHON_BIN=.venv\\Scripts\\python.exe
PORT=3131
